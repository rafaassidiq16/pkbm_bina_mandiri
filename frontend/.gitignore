# ============================================================
# .gitignore — PKBM Bina Mandiri Frontend
# ============================================================

# Dependensi npm — JANGAN di-commit, install ulang via npm install
node_modules/

# File environment — JANGAN di-commit, berisi konfigurasi sensitif
.env
.env.local
.env.*.local

# Output build Vite
dist/
dist-ssr/

# Cache Vite & editor
.vite/
.DS_Store
Thumbs.db
*.local

# Log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
